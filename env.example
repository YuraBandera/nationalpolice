# Пароль до адмін-панелі (/admin)
ADMIN_PASSWORD=changeme-2026

# Discord Webhook для сповіщень про нові заявки та скарги.
# Отримати: Налаштування каналу → Інтеграції → Вебхуки → Новий вебхук → Копіювати URL
DISCORD_WEBHOOK_APPLICATIONS=
DISCORD_WEBHOOK_COMPLAINTS=

# Публічне посилання на Discord-сервер (використовується у контактах/футері)
NEXT_PUBLIC_DISCORD_INVITE=https://discord.gg/N9gFDMs9v

# --- Cloudflare R2: постійне сховище бази (щоб зміни в адмінці зберігались) ---
# Якщо ці змінні задані — база (новини, патрулі, заявки, набір) зберігається у R2
# і переживає перезапуски. Якщо не задані — база у файлі data/db.json (локальна розробка).
# Де взяти: Cloudflare → R2 → Manage R2 API Tokens → Create API Token (Object Read & Write).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Необов'язково: ім'я файлу бази в бакеті (за замовчуванням db.json)
R2_DB_KEY=db.json

# --- Cloudflare R2: публічний бакет для завантаження фото/відео з адмінки ---
# Дозволяє вставляти файли кнопкою «Файл» замість посилань.
# Потрібен ОКРЕМИЙ ПУБЛІЧНИЙ бакет (не той, що для бази!) з увімкненим Public access.
R2_PUBLIC_BUCKET=
# Публічна базова адреса цього бакета (R2.dev URL або власний домен), без слеша в кінці.
# Приклад: https://pub-xxxxxxxx.r2.dev
R2_PUBLIC_BASE_URL=
